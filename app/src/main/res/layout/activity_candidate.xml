<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/layoutCandidateHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#000000"
            android:elevation="8dp"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:paddingTop="18dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ứng viên tuyển dụng"
                        android:textColor="#FFD700"
                        android:textSize="25sp"
                        android:textStyle="bold"
                        android:singleLine="true"
                        android:ellipsize="end" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Duyệt hồ sơ, mời phỏng vấn và xác nhận ứng viên đã phỏng vấn."
                        android:textColor="#CBD5F5"
                        android:textSize="13sp"
                        android:layout_marginTop="3dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnBackEmployee"
                    android:layout_width="124dp"
                    android:layout_height="50dp"
                    android:layout_marginLeft="12dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:text="Nhân viên"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="#000000"
                    android:backgroundTint="@null"
                    android:background="@drawable/hr_logout_bg" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutCandidateFilterToggle"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/hr_card_bg"
                android:paddingLeft="14dp"
                android:paddingRight="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bộ lọc ứng viên"
                    android:textColor="#FFD700"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtCandidateFilterArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▼"
                    android:textColor="#FFD700"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutCandidateFilterContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/hr_card_bg"
                android:padding="14dp"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <EditText
                    android:id="@+id/edtSearchCandidate"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Tìm theo tên hoặc email..."
                    android:singleLine="true"
                    android:textColor="#E5E7EB"
                    android:textColorHint="#8B90A0"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:background="@drawable/employee_input_bg" />

                <EditText
                    android:id="@+id/edtFromDate"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:hint="Từ ngày: yyyy-MM-dd"
                    android:singleLine="true"
                    android:textColor="#E5E7EB"
                    android:textColorHint="#8B90A0"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:background="@drawable/employee_input_bg" />

                <EditText
                    android:id="@+id/edtToDate"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:hint="Đến ngày: yyyy-MM-dd"
                    android:singleLine="true"
                    android:textColor="#E5E7EB"
                    android:textColorHint="#8B90A0"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:background="@drawable/employee_input_bg" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnFilterCandidate"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Lọc"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:backgroundTint="@null"
                        android:background="@drawable/hr_logout_bg" />

                    <Button
                        android:id="@+id/btnResetCandidate"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginLeft="10dp"
                        android:text="Xóa lọc"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="@null"
                        android:background="@drawable/employee_button_dark_bg" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnDownloadSelectedFiles"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:text="⬇ Tải file các ứng viên đã chọn"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="@null"
                android:background="@drawable/employee_button_dark_bg" />

            <Button
                android:id="@+id/btnExportDeleteCandidate"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:text="✔ Xác nhận đã phỏng vấn và xuất PDF"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#000000"
                android:backgroundTint="@null"
                android:background="@drawable/hr_logout_bg" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/scrollCandidate"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/layoutCandidateContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:paddingTop="12dp"
                android:paddingBottom="128dp">

                <LinearLayout
                    android:id="@+id/layoutCandidateList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_nav_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />
</FrameLayout>