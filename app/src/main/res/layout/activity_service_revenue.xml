<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainServiceRevenueLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:id="@+id/layoutServiceRevenueHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#000000"
            android:elevation="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="18dp"
            android:paddingTop="18dp"
            android:paddingRight="18dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvBrand"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TBT CENTER"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Service revenue overview"
                    android:textColor="#E5E7EB"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDateRange"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Theo dõi doanh thu dịch vụ theo bộ lọc, thời gian và nhóm biểu đồ."
                    android:textColor="#CBD5F5"
                    android:textSize="13sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnLogoutServiceRevenue"
                android:layout_width="112dp"
                android:layout_height="54dp"
                android:layout_marginLeft="10dp"
                android:background="@drawable/hr_logout_bg"
                android:backgroundTint="@null"
                android:text="Đăng xuất"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- BODY -->
        <ScrollView
            android:id="@+id/scrollServiceRevenue"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/layoutServiceRevenueBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="18dp"
                android:paddingTop="12dp"
                android:paddingRight="18dp"
                android:paddingBottom="128dp">

                <!-- ACTION CARD -->
                <LinearLayout
                    android:id="@+id/layoutServiceRevenueAction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/hr_card_bg"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="BÁO CÁO DOANH THU DỊCH VỤ"
                        android:textColor="#FFD700"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnExportExcel"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginRight="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/hr_logout_bg"
                            android:backgroundTint="@null"
                            android:text="Export Excel"
                            android:textAllCaps="false"
                            android:textColor="#000000"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnExportPdf"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginLeft="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/hr_logout_bg"
                            android:backgroundTint="@null"
                            android:text="Export PDF"
                            android:textAllCaps="false"
                            android:textColor="#000000"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- FILTER CARD -->
                <LinearLayout
                    android:id="@+id/layoutFilterCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/hr_card_bg"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:id="@+id/layoutFilterHeader"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="BỘ LỌC"
                            android:textColor="#FFD700"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvFilterArrow"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:gravity="center"
                            android:text="▼"
                            android:textColor="#FFD700"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutFilterContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Tìm loại dịch vụ"
                            android:textColor="#CBD5F5"
                            android:textSize="12sp" />

                        <EditText
                            android:id="@+id/edtSearchService"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/employee_input_bg"
                            android:hint="Nhập loại dịch vụ hoặc ngày..."
                            android:paddingLeft="12dp"
                            android:paddingRight="12dp"
                            android:singleLine="true"
                            android:textColor="#E5E7EB"
                            android:textColorHint="#64748B"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Loại dịch vụ"
                            android:textColor="#CBD5F5"
                            android:textSize="12sp" />

                        <Spinner
                            android:id="@+id/spTypeFilter"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/employee_input_bg"
                            android:paddingLeft="8dp"
                            android:paddingRight="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Kiểu biểu đồ"
                            android:textColor="#CBD5F5"
                            android:textSize="12sp" />

                        <Spinner
                            android:id="@+id/spGroupType"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/employee_input_bg"
                            android:paddingLeft="8dp"
                            android:paddingRight="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Khoảng thời gian"
                            android:textColor="#CBD5F5"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/edtFrom"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_marginRight="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/employee_input_bg"
                                android:focusable="false"
                                android:hint="Từ ngày"
                                android:paddingLeft="12dp"
                                android:paddingRight="12dp"
                                android:singleLine="true"
                                android:textColor="#E5E7EB"
                                android:textColorHint="#64748B"
                                android:textSize="13sp" />

                            <EditText
                                android:id="@+id/edtTo"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_marginLeft="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/employee_input_bg"
                                android:focusable="false"
                                android:hint="Đến ngày"
                                android:paddingLeft="12dp"
                                android:paddingRight="12dp"
                                android:singleLine="true"
                                android:textColor="#E5E7EB"
                                android:textColorHint="#64748B"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Khoảng doanh thu"
                            android:textColor="#CBD5F5"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/edtAmountMin"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_marginRight="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/employee_input_bg"
                                android:hint="Từ"
                                android:inputType="numberDecimal"
                                android:paddingLeft="12dp"
                                android:paddingRight="12dp"
                                android:singleLine="true"
                                android:textColor="#E5E7EB"
                                android:textColorHint="#64748B"
                                android:textSize="13sp" />

                            <EditText
                                android:id="@+id/edtAmountMax"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_marginLeft="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/employee_input_bg"
                                android:hint="Đến"
                                android:inputType="numberDecimal"
                                android:paddingLeft="12dp"
                                android:paddingRight="12dp"
                                android:singleLine="true"
                                android:textColor="#E5E7EB"
                                android:textColorHint="#64748B"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnApplyFilter"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_marginRight="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/hr_logout_bg"
                                android:backgroundTint="@null"
                                android:text="Lọc"
                                android:textAllCaps="false"
                                android:textColor="#000000"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/btnResetFilter"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_marginLeft="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/hr_logout_bg"
                                android:backgroundTint="@null"
                                android:text="Đặt lại"
                                android:textAllCaps="false"
                                android:textColor="#000000"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- KPI BUILD BY JAVA -->
                <LinearLayout
                    android:id="@+id/layoutKpiList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- CHART CARD -->
                <LinearLayout
                    android:id="@+id/layoutChartCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/hr_card_bg"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvChartTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="REVENUE CHART - THEO THÁNG"
                        android:textColor="#FFD700"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvChartNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Biểu đồ doanh thu dịch vụ theo ngày, tháng hoặc năm."
                        android:textColor="#CBD5F5"
                        android:textSize="12sp" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="16dp">

                        <com.neith.subjectdemo.fn.DonutChartView
                            android:id="@+id/donutChart"
                            android:layout_width="170dp"
                            android:layout_height="170dp"
                            android:layout_gravity="center" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvCenterType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TỔNG"
                                android:textColor="#E5E7EB"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvCenterValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="100%"
                                android:textColor="#06B6D4"
                                android:textSize="9sp" />
                        </LinearLayout>
                    </FrameLayout>

                    <GridLayout
                        android:id="@+id/glLegend"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:columnCount="2"
                        android:useDefaultMargins="true" />
                </LinearLayout>

                <!-- DETAIL LIST BUILD BY JAVA -->
                <LinearLayout
                    android:id="@+id/layoutServiceRevenueList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- PAGINATION -->
                <LinearLayout
                    android:id="@+id/layoutPagination"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="14dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvPageInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Page 1 / 1"
                        android:textColor="#CBD5F5"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/layoutPageNumbers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_nav_bg"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingTop="8dp"
        android:paddingRight="8dp"
        android:paddingBottom="8dp" />

</FrameLayout>