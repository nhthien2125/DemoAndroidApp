<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="32dp"
            android:paddingRight="32dp"
            android:paddingTop="5dp"
            android:paddingBottom="28dp">

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="280dp"
                android:layout_height="230dp"
                android:layout_gravity="center"
                android:src="@drawable/logo"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:layout_marginBottom="15dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="36dp"
                android:text="Hi Welcome!"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="44sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="E-mail Address / Username"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/auth_input"
                android:paddingLeft="16dp"
                android:paddingRight="18dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_user"
                    android:scaleType="fitCenter"
                    android:layout_marginRight="12dp" />

                <EditText
                    android:id="@+id/edtUsername"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Insert your E-mail or Username here"
                    android:singleLine="true"
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:textColorHint="#6F5A00"
                    android:background="@android:color/transparent"
                    android:padding="0dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/auth_input"
                android:paddingLeft="16dp"
                android:paddingRight="14dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_lock"
                    android:scaleType="fitCenter"
                    android:layout_marginRight="12dp" />

                <EditText
                    android:id="@+id/edtPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Insert your Password here"
                    android:singleLine="true"
                    android:inputType="textPassword"
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:textColorHint="#6F5A00"
                    android:background="@android:color/transparent"
                    android:padding="0dp" />

                <ImageView
                    android:id="@+id/imgTogglePassword"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_eye_off"
                    android:padding="3dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="26dp">

                <CheckBox
                    android:id="@+id/chkRemember"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Remember Me"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:buttonTint="#FFFFFF" />

                <TextView
                    android:id="@+id/txtForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forgot Password?"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFD400"
            android:orientation="vertical"
            android:paddingLeft="32dp"
            android:paddingRight="32dp"
            android:paddingTop="48dp"
            android:paddingBottom="54dp">

            <Button
                android:id="@+id/btnSignIn"
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:text="Sign in"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="#000000"
                android:backgroundTint="@null"
                android:background="@drawable/auth_button_white" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="or"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginLeft="28dp"
                    android:layout_marginRight="28dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#FFFFFF" />
            </LinearLayout>

            <Button
                android:id="@+id/btnGoSignUp"
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:text="Create an Account"
                android:backgroundTint="@null"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/auth_button_light" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>