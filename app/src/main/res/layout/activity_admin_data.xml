<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/layoutAdminDataHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#000000"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quản lý dữ liệu"
                android:textColor="#FFD700"
                android:textSize="26sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtAdminDataSub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Chỉnh sửa dữ liệu và SQL console."
                android:textColor="#CBD5F5"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Body -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/layoutAdminDataBody"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp">

                <!-- SQL Console -->
                <EditText
                    android:id="@+id/edtSQLConsole"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:hint="Nhập SQL command..."
                    android:textColor="#FFFFFF"
                    android:textColorHint="#8B90A0"
                    android:padding="12dp"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:scrollbars="vertical"
                    android:layout_marginBottom="10dp"/>

                <!-- Execute SQL -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnExecuteSQL"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Execute"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:background="@drawable/hr_logout_bg"
                    android:layout_marginBottom="10dp"/>

                <!-- List bảng -->
                <LinearLayout
                    android:id="@+id/layoutTableList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- BottomNav -->
    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_nav_bg"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp"/>
</FrameLayout>