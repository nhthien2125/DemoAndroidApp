<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/layoutProjectHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#000000"
            android:elevation="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:paddingTop="18dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:text="Dự án"
                    android:textColor="#FFD700"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Quản lý dự án theo hợp đồng, khu vực, khách hàng và nhân sự tham gia."
                    android:textColor="#CBD5F5"
                    android:textSize="13sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnAddProject"
                android:layout_width="116dp"
                android:layout_height="56dp"
                android:layout_marginLeft="12dp"
                android:background="@drawable/hr_logout_bg"
                android:backgroundTint="@null"
                android:text="+ Thêm"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/scrollProject"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/layoutProjectContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:paddingTop="12dp"
                android:paddingBottom="128dp">

                <LinearLayout
                    android:id="@+id/layoutProjectFilterToggle"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/hr_card_bg"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bộ lọc &amp; tìm kiếm"
                            android:textColor="#FFD700"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bấm để lọc theo mã, tên, khách hàng, khu vực, trạng thái..."
                            android:textColor="#CBD5F5"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtProjectFilterArrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▼"
                        android:textColor="#FFD700"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutProjectFilterContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/hr_card_bg"
                    android:padding="14dp"
                    android:layout_marginBottom="14dp">

                    <EditText
                        android:id="@+id/edtSearchProject"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Tìm mã, tên, hợp đồng, khách hàng, khu vực..."
                        android:textColor="#E5E7EB"
                        android:textColorHint="#8B90A0"
                        android:singleLine="true"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:background="@drawable/employee_input_bg" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kiểu tìm kiếm"
                        android:textColor="#CBD5F5"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spnProjectSearchMode"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:background="@drawable/employee_input_bg"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loại hợp đồng"
                        android:textColor="#CBD5F5"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spnProjectTypeFilter"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:background="@drawable/employee_input_bg"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Khu vực"
                        android:textColor="#CBD5F5"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spnProjectAreaFilter"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:background="@drawable/employee_input_bg"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trạng thái"
                        android:textColor="#CBD5F5"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spnProjectStatusFilter"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:background="@drawable/employee_input_bg"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sắp xếp"
                        android:textColor="#CBD5F5"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spnProjectSort"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:background="@drawable/employee_input_bg"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <Button
                            android:id="@+id/btnApplyProjectFilter"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="Áp dụng"
                            android:textAllCaps="false"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:backgroundTint="@null"
                            android:background="@drawable/hr_logout_bg" />

                        <Button
                            android:id="@+id/btnResetProjectFilter"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:layout_marginLeft="10dp"
                            android:text="Đặt lại"
                            android:textAllCaps="false"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="@null"
                            android:background="@drawable/employee_button_dark_bg" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutProjectList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_nav_bg"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />

</FrameLayout>