<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/layoutAdminLogHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#000000"
            android:elevation="8dp"
            android:orientation="vertical"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:paddingTop="18dp"
            android:paddingBottom="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nhật ký hoạt động"
                android:textColor="#FFD700"
                android:textSize="25sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Theo dõi ACTIVITY_LOG, lọc theo action, người thao tác và khoảng ngày."
                android:textColor="#CBD5F5"
                android:textSize="13sp" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/scrollAdminLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/layoutAdminLogBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:paddingTop="12dp"
                android:paddingBottom="128dp">

                <LinearLayout
                    android:id="@+id/layoutAdminLogFilter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/hr_card_bg"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="14dp">

                    <EditText
                        android:id="@+id/edtSearchAdminLog"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/employee_input_bg"
                        android:hint="Tìm mô tả, user, action..."
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:singleLine="true"
                        android:textColor="#E5E7EB"
                        android:textColorHint="#8B90A0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="4dp"
                        android:text="Action"
                        android:textColor="#CBD5F5"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spnAdminLogAction"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:background="@drawable/employee_input_bg"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/edtAdminLogFrom"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:background="@drawable/employee_input_bg"
                            android:hint="Từ ngày"
                            android:paddingLeft="14dp"
                            android:paddingRight="14dp"
                            android:textColor="#E5E7EB"
                            android:textColorHint="#8B90A0" />

                        <EditText
                            android:id="@+id/edtAdminLogTo"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginLeft="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/employee_input_bg"
                            android:hint="Đến ngày"
                            android:paddingLeft="14dp"
                            android:paddingRight="14dp"
                            android:textColor="#E5E7EB"
                            android:textColorHint="#8B90A0" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnApplyAdminLogFilter"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:background="@drawable/hr_logout_bg"
                            android:backgroundTint="@null"
                            android:text="Áp dụng"
                            android:textAllCaps="false"
                            android:textColor="#000000"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnResetAdminLogFilter"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_marginLeft="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/employee_button_dark_bg"
                            android:backgroundTint="@null"
                            android:text="Đặt lại"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutAdminLogList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_nav_bg"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />

</FrameLayout>