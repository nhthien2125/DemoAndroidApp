<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_finance_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:id="@+id/layoutFinanceHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#000000"
            android:elevation="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="18dp"
            android:paddingTop="18dp"
            android:paddingRight="18dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvBrand"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TBT CENTER"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Finance dashboard"
                    android:textColor="#E5E7EB"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Theo dõi doanh thu, chi phí và danh sách dự án tài chính."
                    android:textColor="#CBD5F5"
                    android:textSize="13sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnLogoutFinance"
                android:layout_width="112dp"
                android:layout_height="54dp"
                android:layout_marginLeft="10dp"
                android:background="@drawable/hr_logout_bg"
                android:backgroundTint="@null"
                android:text="Đăng xuất"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- BODY -->
        <ScrollView
            android:id="@+id/scrollFinance"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/layoutFinanceBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="18dp"
                android:paddingTop="12dp"
                android:paddingRight="18dp"
                android:paddingBottom="128dp">

                <!-- EXPORT CARD -->
                <LinearLayout
                    android:id="@+id/layoutFinanceAction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/hr_card_bg"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="BÁO CÁO TÀI CHÍNH"
                        android:textColor="#FFD700"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnExportExcel"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/hr_logout_bg"
                            android:backgroundTint="@null"
                            android:text="Xuất Excel"
                            android:textAllCaps="false"
                            android:textColor="#000000"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnExportPdf"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginLeft="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/employee_button_dark_bg"
                            android:backgroundTint="@null"
                            android:text="Xuất PDF"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnBackAdmin"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/employee_button_dark_bg"
                        android:backgroundTint="@null"
                        android:text="Quay lại trang Admin"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- SUMMARY -->
                <LinearLayout
                    android:id="@+id/layoutSummaryList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- COLLAPSE FILTER CARD -->
                <LinearLayout
                    android:id="@+id/layoutFilterCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/hr_card_bg"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:id="@+id/layoutFilterHeader"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="BỘ LỌC DỰ ÁN TÀI CHÍNH"
                            android:textColor="#FFD700"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvFilterArrow"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/employee_input_bg"
                            android:gravity="center"
                            android:text="▼"
                            android:textColor="#FFD700"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutFilterContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Tìm theo tên, mã dự án hoặc loại"
                            android:textColor="#CBD5F5"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/edtSearchProject"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/employee_input_bg"
                            android:hint="Nhập tên dự án, mã dự án, loại hợp đồng..."
                            android:inputType="text"
                            android:paddingLeft="14dp"
                            android:paddingRight="14dp"
                            android:singleLine="true"
                            android:textColor="#E5E7EB"
                            android:textColorHint="#8B90A0"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Loại hợp đồng"
                            android:textColor="#CBD5F5"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spTypeFilter"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/employee_input_bg"
                            android:paddingLeft="12dp"
                            android:paddingRight="12dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Sắp xếp"
                            android:textColor="#CBD5F5"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spSortFilter"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/employee_input_bg"
                            android:paddingLeft="12dp"
                            android:paddingRight="12dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Khoảng doanh thu"
                            android:textColor="#CBD5F5"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/edtRevenueMin"
                                android:layout_width="0dp"
                                android:layout_height="50dp"
                                android:layout_weight="1"
                                android:background="@drawable/employee_input_bg"
                                android:hint="Từ"
                                android:inputType="numberDecimal"
                                android:paddingLeft="14dp"
                                android:paddingRight="14dp"
                                android:singleLine="true"
                                android:textColor="#E5E7EB"
                                android:textColorHint="#8B90A0"
                                android:textSize="13sp" />

                            <EditText
                                android:id="@+id/edtRevenueMax"
                                android:layout_width="0dp"
                                android:layout_height="50dp"
                                android:layout_marginLeft="10dp"
                                android:layout_weight="1"
                                android:background="@drawable/employee_input_bg"
                                android:hint="Đến"
                                android:inputType="numberDecimal"
                                android:paddingLeft="14dp"
                                android:paddingRight="14dp"
                                android:singleLine="true"
                                android:textColor="#E5E7EB"
                                android:textColorHint="#8B90A0"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Khoảng chi phí"
                            android:textColor="#CBD5F5"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/edtCostMin"
                                android:layout_width="0dp"
                                android:layout_height="50dp"
                                android:layout_weight="1"
                                android:background="@drawable/employee_input_bg"
                                android:hint="Từ"
                                android:inputType="numberDecimal"
                                android:paddingLeft="14dp"
                                android:paddingRight="14dp"
                                android:singleLine="true"
                                android:textColor="#E5E7EB"
                                android:textColorHint="#8B90A0"
                                android:textSize="13sp" />

                            <EditText
                                android:id="@+id/edtCostMax"
                                android:layout_width="0dp"
                                android:layout_height="50dp"
                                android:layout_marginLeft="10dp"
                                android:layout_weight="1"
                                android:background="@drawable/employee_input_bg"
                                android:hint="Đến"
                                android:inputType="numberDecimal"
                                android:paddingLeft="14dp"
                                android:paddingRight="14dp"
                                android:singleLine="true"
                                android:textColor="#E5E7EB"
                                android:textColorHint="#8B90A0"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnApplyFilter"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:background="@drawable/hr_logout_bg"
                                android:backgroundTint="@null"
                                android:text="Lọc"
                                android:textAllCaps="false"
                                android:textColor="#000000"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/btnResetFilter"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_marginLeft="10dp"
                                android:layout_weight="1"
                                android:background="@drawable/employee_button_dark_bg"
                                android:backgroundTint="@null"
                                android:text="Đặt lại"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- PROJECT LIST -->
                <LinearLayout
                    android:id="@+id/layoutProjectHighlights"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_nav_bg"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="6dp"
        android:paddingTop="8dp"
        android:paddingRight="6dp"
        android:paddingBottom="8dp" />

</FrameLayout>