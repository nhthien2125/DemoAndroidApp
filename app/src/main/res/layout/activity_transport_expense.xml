<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainTransportExpenseLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:id="@+id/layoutTransportHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#000000"
            android:elevation="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="18dp"
            android:paddingTop="18dp"
            android:paddingRight="18dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvBrand"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TBT CENTER"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Raw material transport expenses"
                    android:textColor="#E5E7EB"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSubTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Theo dõi chi phí vận chuyển nguyên vật liệu theo dự án."
                    android:textColor="#CBD5F5"
                    android:textSize="13sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnLogoutTransport"
                android:layout_width="112dp"
                android:layout_height="54dp"
                android:layout_marginLeft="10dp"
                android:background="@drawable/hr_logout_bg"
                android:backgroundTint="@null"
                android:text="Đăng xuất"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- BODY -->
        <ScrollView
            android:id="@+id/scrollTransport"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/layoutTransportBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="18dp"
                android:paddingTop="12dp"
                android:paddingRight="18dp"
                android:paddingBottom="128dp">

                <!-- SUMMARY CARD -->
                <LinearLayout
                    android:id="@+id/layoutSummaryCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/hr_card_bg"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="TỔNG QUAN CHI PHÍ"
                        android:textColor="#FFD700"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTotalExpense"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="$0M"
                        android:textColor="#22C55E"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Tổng chi phí vận chuyển sau bộ lọc."
                        android:textColor="#CBD5F5"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- ACTION CARD -->
                <LinearLayout
                    android:id="@+id/layoutActionCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/hr_card_bg"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="XUẤT BÁO CÁO"
                        android:textColor="#FFD700"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnExportExcel"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginRight="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/hr_logout_bg"
                            android:backgroundTint="@null"
                            android:text="Export Excel"
                            android:textAllCaps="false"
                            android:textColor="#000000"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnExportPdf"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginLeft="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/hr_logout_bg"
                            android:backgroundTint="@null"
                            android:text="Export PDF"
                            android:textAllCaps="false"
                            android:textColor="#000000"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- FILTER CARD -->
                <LinearLayout
                    android:id="@+id/layoutFilterCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/hr_card_bg"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:id="@+id/layoutFilterHeader"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="BỘ LỌC DỮ LIỆU"
                            android:textColor="#FFD700"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvFilterArrow"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:gravity="center"
                            android:text="▼"
                            android:textColor="#FFD700"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutFilterContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Loại vật liệu"
                            android:textColor="#CBD5F5"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spFilter"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/employee_input_bg"
                            android:paddingLeft="12dp"
                            android:paddingRight="12dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Tìm kiếm"
                            android:textColor="#CBD5F5"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etSearch"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/employee_input_bg"
                            android:hint="Tìm theo mã vận chuyển, vật liệu hoặc dự án..."
                            android:inputType="text"
                            android:paddingLeft="14dp"
                            android:paddingRight="14dp"
                            android:singleLine="true"
                            android:textColor="#E5E7EB"
                            android:textColorHint="#8B90A0"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Khoảng thời gian"
                            android:textColor="#CBD5F5"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/edtFrom"
                                android:layout_width="0dp"
                                android:layout_height="50dp"
                                android:layout_marginRight="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/employee_input_bg"
                                android:focusable="false"
                                android:hint="Từ ngày"
                                android:paddingLeft="14dp"
                                android:paddingRight="14dp"
                                android:singleLine="true"
                                android:textColor="#E5E7EB"
                                android:textColorHint="#8B90A0"
                                android:textSize="13sp" />

                            <EditText
                                android:id="@+id/edtTo"
                                android:layout_width="0dp"
                                android:layout_height="50dp"
                                android:layout_marginLeft="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/employee_input_bg"
                                android:focusable="false"
                                android:hint="Đến ngày"
                                android:paddingLeft="14dp"
                                android:paddingRight="14dp"
                                android:singleLine="true"
                                android:textColor="#E5E7EB"
                                android:textColorHint="#8B90A0"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Khoảng chi phí"
                            android:textColor="#CBD5F5"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/edtCostMin"
                                android:layout_width="0dp"
                                android:layout_height="50dp"
                                android:layout_marginRight="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/employee_input_bg"
                                android:hint="Từ"
                                android:inputType="numberDecimal"
                                android:paddingLeft="14dp"
                                android:paddingRight="14dp"
                                android:singleLine="true"
                                android:textColor="#E5E7EB"
                                android:textColorHint="#8B90A0"
                                android:textSize="13sp" />

                            <EditText
                                android:id="@+id/edtCostMax"
                                android:layout_width="0dp"
                                android:layout_height="50dp"
                                android:layout_marginLeft="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/employee_input_bg"
                                android:hint="Đến"
                                android:inputType="numberDecimal"
                                android:paddingLeft="14dp"
                                android:paddingRight="14dp"
                                android:singleLine="true"
                                android:textColor="#E5E7EB"
                                android:textColorHint="#8B90A0"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnApplyFilter"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_marginRight="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/hr_logout_bg"
                                android:backgroundTint="@null"
                                android:text="Lọc"
                                android:textAllCaps="false"
                                android:textColor="#000000"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/btnResetFilter"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_marginLeft="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/hr_logout_bg"
                                android:backgroundTint="@null"
                                android:text="Đặt lại"
                                android:textAllCaps="false"
                                android:textColor="#000000"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- WATERFALL CHART CARD -->
                <LinearLayout
                    android:id="@+id/layoutChartCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/hr_card_bg"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvChartTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="BIỂU ĐỒ THÁC NƯỚC - CHI PHÍ VẬN CHUYỂN"
                        android:textColor="#FFD700"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvChartNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Biểu đồ Thác nước thể hiện chi phí tăng dần theo từng loại vật liệu."
                        android:textColor="#CBD5F5"
                        android:textSize="12sp" />

                    <FrameLayout
                        android:id="@+id/layoutChartContainer"
                        android:layout_width="match_parent"
                        android:layout_height="260dp"
                        android:layout_marginTop="12dp"
                        android:background="#111827" />
                </LinearLayout>

                <!-- LIST BUILD BY JAVA -->
                <LinearLayout
                    android:id="@+id/layoutExpenseList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- PAGINATION -->
                <LinearLayout
                    android:id="@+id/layoutPaginationCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/hr_card_bg"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvPageInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Page 1 / 1"
                        android:textColor="#E5E7EB"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/layoutPageNumbers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_nav_bg"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingTop="8dp"
        android:paddingRight="8dp"
        android:paddingBottom="8dp" />

</FrameLayout>